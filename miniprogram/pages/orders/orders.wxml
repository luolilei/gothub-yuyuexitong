<view class="page">
  <view class="section">
    <view class="title">我的预约</view>
    <view class="subtitle">查看已提交的上门服务预约和处理状态。</view>
  </view>

  <view wx:if="{{!appointments.length}}" class="card emptyState">
    <view>暂无预约记录</view>
  </view>

  <view wx:for="{{appointments}}" wx:key="id" class="card orderCard">
    <view class="orderHead">
      <view>{{item.service}}</view>
      <text class="badge {{item.status}}">{{statusText[item.status]}}</text>
    </view>
    <view class="meta">{{item.booking_date}} {{item.booking_time}}</view>
    <view class="address">{{item.address}}</view>
    <view wx:if="{{item.note}}" class="note">{{item.note}}</view>
  </view>
</view>
